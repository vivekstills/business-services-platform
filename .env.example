# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# ─── Business identity ────────────────────────────────────────────────────────
# Your brand name shown in email subject lines and greetings.
BUSINESS_NAME="YourBrand"

# The email address that receives new enquiry notifications.
BUSINESS_EMAIL="owner@yourbrand.com"

# The mobile number that receives SMS alerts (E.164 format, e.g. +919876543210).
BUSINESS_PHONE="+919876543210"

# ─── SMTP / Email settings ────────────────────────────────────────────────────
# Works with Gmail, Outlook, Zoho, SendGrid SMTP, etc.
#
# Gmail quick-start:
#   1. Enable 2FA on your Google account.
#   2. Go to myaccount.google.com → Security → App Passwords → create one.
#   3. Use that 16-char app password as SMTP_PASS (not your real Gmail password).
#
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"          # set to "true" for port 465
SMTP_USER="you@gmail.com"    # the sending address
SMTP_PASS="xxxx xxxx xxxx xxxx"   # Gmail App Password

# ─── Twilio SMS settings (optional) ──────────────────────────────────────────
# Create a free account at twilio.com to get a SID, token, and phone number.
# If these are left blank, SMS notifications are silently skipped.
TWILIO_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_TOKEN="your_auth_token"
TWILIO_FROM="+1415XXXXXXX"   # your Twilio phone number

# ─── API server port ──────────────────────────────────────────────────────────
SERVER_PORT="4000"

# ─── Razorpay payment gateway ─────────────────────────────────────────────────
# Get your keys from https://dashboard.razorpay.com/app/keys
# Use test keys during development (rzp_test_...), live keys in production.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
# Webhook secret from Dashboard → Webhooks → secret
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# ─── Admin dashboard ──────────────────────────────────────────────────────────
# Password for admin login at /admin. Required for content editing.
ADMIN_PASSWORD="your-admin-password"
