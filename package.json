{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite --port=5173 --host=0.0.0.0\"",
    "server": "tsx watch server.ts",
    "seed": "tsx scripts/seed-content.ts",
    "generate:route-slugs": "tsx scripts/generate-route-slugs.ts",
    "build": "cp data/content.json public/content.json && node scripts/run-sitemap-if-present.mjs && vite build",
    "build:prerender": "cp data/content.json public/content.json && node scripts/run-sitemap-if-present.mjs && vite build && tsx scripts/prerender.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.1",
    "razorpay": "^2.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.30.1",
    "twilio": "^5.12.2",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^7.0.11",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
